# =============================================================================
# SchoolMitra ERP — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# Secrets are SERVER-SIDE ONLY. Only NEXT_PUBLIC_ prefix for non-sensitive config.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="SchoolMitra ERP"
NEXT_PUBLIC_APP_VERSION="0.1.0"

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://schoolmitra:schoolmitra_dev@localhost:5432/schoolmitra_erp"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth (NextAuth.js v5) ─────────────────────────────────────────────────────
AUTH_SECRET="change-me-to-a-random-64-char-string-in-production"
AUTH_URL=http://localhost:3000

# ── Encryption (AES-256 for PII columns) ─────────────────────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="change-me-to-a-random-64-hex-char-string-in-production"
ENCRYPTION_IV_LENGTH=16

# ── Storage (S3-compatible: MinIO in dev, AWS S3 in prod) ─────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_REGION="ap-south-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET_DOCUMENTS="schoolmitra-documents"
S3_BUCKET_PHOTOS="schoolmitra-photos"
S3_SIGNED_URL_EXPIRY_SECONDS=900

# ── Email (SMTP / Nodemailer) ─────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="noreply@schoolmitra.in"
SMTP_PASS="change-me"
EMAIL_FROM="SchoolMitra ERP <noreply@schoolmitra.in>"

# ── SMS Gateway (MSG91 — primary for India) ───────────────────────────────────
SMS_PROVIDER="msg91"
MSG91_AUTH_KEY="change-me"
MSG91_SENDER_ID="SCHOLA"
MSG91_TEMPLATE_ID_OTP="change-me"
MSG91_TEMPLATE_ID_ABSENCE="change-me"
MSG91_TEMPLATE_ID_FEE_REMINDER="change-me"

# ── Payment Gateway (Razorpay) ────────────────────────────────────────────────
RAZORPAY_KEY_ID="change-me"
RAZORPAY_KEY_SECRET="change-me"
RAZORPAY_WEBHOOK_SECRET="change-me"
NEXT_PUBLIC_RAZORPAY_KEY_ID="change-me"

# ── Firebase FCM (Push Notifications) ────────────────────────────────────────
FIREBASE_PROJECT_ID="change-me"
FIREBASE_PRIVATE_KEY="change-me"
FIREBASE_CLIENT_EMAIL="change-me"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_UNAUTH_RPM=100
RATE_LIMIT_AUTH_RPM=500

# ── DPDP Compliance ───────────────────────────────────────────────────────────
DPO_EMAIL="dpo@schoolmitra.in"
DPO_NAME="Data Protection Officer"
PRIVACY_NOTICE_VERSION="1.0"
CONSENT_WITHDRAWAL_HOURS=24

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_HOSTEL=false
NEXT_PUBLIC_FEATURE_BIOMETRIC=false
NEXT_PUBLIC_FEATURE_GPS_TRACKER=false

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
LOG_REDACT_PII=true

# ── BullMQ (Job Queues) ───────────────────────────────────────────────────────
BULLMQ_PREFIX="schoolmitra"
