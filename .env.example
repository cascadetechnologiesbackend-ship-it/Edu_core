# Environment Variables for SchoolMitra ERP

# ─── Database (PostgreSQL via Drizzle) ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/schoolmitra"

# ─── NextAuth / Authentication ────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="supersecret_nextauth_key_must_be_32_chars_long"
NEXTAUTH_URL="http://localhost:3000"

# ─── Redis (Caching & Rate Limiting & Account Lockout) ────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Encryption (AES-256 for DPDP compliance / PII storage) ───────────────────
# Generate a 32-byte hex string: openssl rand -hex 32
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# ─── S3 / MinIO (Document Storage) ────────────────────────────────────────────
# Local MinIO default settings
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="admin"
S3_SECRET_KEY="password123"
S3_BUCKET="schoolmitra-docs"

# ─── External APIs (SMS/Email) ────────────────────────────────────────────────
# (Stubbed for now, replace with actual provider keys)
MSG91_API_KEY=""
SENDGRID_API_KEY=""

# ─── Feature Flags / Telemetry ────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
